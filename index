<!DOCTYPE html>
<html lang="et">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hangete dashboard</title>
<style>
  :root {
    --bg: #faf9f6;
    --surface: #ffffff;
    --surface-muted: #f2f1ec;
    --border: rgba(11,11,11,0.10);
    --border-strong: rgba(11,11,11,0.18);
    --text-primary: #16160f;
    --text-secondary: #57564d;
    --text-muted: #8a8980;
    --accent: #1d5f99;
    --accent-bg: #e6f0f8;
    --won: #0f6e56;
    --won-bg: #e1f5ee;
    --lost: #993c1d;
    --lost-bg: #faece7;
    --ours: #57564d;
    --radius: 10px;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #171714;
      --surface: #201f1b;
      --surface-muted: #262521;
      --border: rgba(255,255,255,0.10);
      --border-strong: rgba(255,255,255,0.20);
      --text-primary: #f3f2ed;
      --text-secondary: #b9b7ac;
      --text-muted: #85837a;
      --accent: #6fb1e8;
      --accent-bg: #1c3346;
      --won: #5dcaa5;
      --won-bg: #133c31;
      --lost: #f0997b;
      --lost-bg: #4a2417;
      --ours: #b9b7ac;
    }
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    background: var(--bg);
    color: var(--text-primary);
    font-family: -apple-system, "Segoe UI", Helvetica, Arial, sans-serif;
    font-size: 14px;
    line-height: 1.5;
    padding: 2rem 1.5rem 4rem;
  }
  .wrap { max-width: 920px; margin: 0 auto; }
  h1 { font-size: 20px; font-weight: 600; margin: 0 0 4px; }
  .sub { color: var(--text-secondary); margin: 0 0 1.75rem; font-size: 13px; }
  .metrics { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 10px; margin-bottom: 1.75rem; }
  .metric { background: var(--surface-muted); border-radius: var(--radius); padding: 14px; }
  .metric .label { font-size: 12px; color: var(--text-secondary); margin: 0 0 4px; }
  .metric .value { font-size: 20px; font-weight: 600; margin: 0; }

  .panel { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 18px 20px; margin-bottom: 1.5rem; }
  .panel h2 { font-size: 15px; font-weight: 600; margin: 0 0 12px; display: flex; align-items: center; justify-content: space-between; cursor: pointer; }
  .panel h2 .chev { font-size: 12px; color: var(--text-muted); transition: transform 0.15s; }
  .panel.collapsed .body { display: none; }
  .panel.collapsed h2 .chev { transform: rotate(-90deg); }

  .grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 10px 14px; }
  label { display: block; font-size: 12px; color: var(--text-secondary); margin-bottom: 4px; }
  input[type=text], input[type=number], select, textarea {
    width: 100%; padding: 8px 10px; border-radius: 7px; border: 1px solid var(--border-strong);
    background: var(--surface); color: var(--text-primary); font-size: 13px; font-family: inherit;
  }
  input:focus, select:focus, textarea:focus { outline: 2px solid var(--accent); outline-offset: 1px; }
  .field { margin-bottom: 10px; }
  .field.full { grid-column: 1 / -1; }
  textarea { min-height: 90px; resize: vertical; font-family: ui-monospace, monospace; font-size: 12px; }

  button {
    font-family: inherit; font-size: 13px; font-weight: 500; cursor: pointer;
    border-radius: 7px; border: 1px solid var(--border-strong); background: var(--surface);
    color: var(--text-primary); padding: 8px 14px;
  }
  button:hover { background: var(--surface-muted); }
  button.primary { background: var(--accent); border-color: var(--accent); color: white; }
  button.primary:hover { opacity: 0.92; }
  button.ghost { border-color: transparent; padding: 6px 8px; color: var(--text-secondary); }
  button.small { padding: 5px 10px; font-size: 12px; }
  .row-actions { display: flex; gap: 8px; margin-top: 10px; }

  .toolbar { display: flex; align-items: center; gap: 14px; margin-bottom: 10px; font-size: 12px; color: var(--text-secondary); flex-wrap: wrap; }
  .toolbar label { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--text-secondary); margin: 0; }
  .toolbar .spacer { flex: 1; }
  .legend-dot { width: 9px; height: 9px; border-radius: 2px; display: inline-block; }

  .crit-row { display: grid; grid-template-columns: 1.4fr 1fr 1fr 1fr auto; gap: 8px; margin-bottom: 8px; align-items: end; }
  .crit-row label { margin-bottom: 4px; }
  .crit-row .rm { padding: 8px 10px; }

  .tender { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 12px 16px; margin-bottom: 8px; }
  .tender-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; gap: 8px; }
  .tender-head .name { font-weight: 600; font-size: 14px; }
  .badge { font-size: 11px; padding: 3px 10px; border-radius: 6px; font-weight: 500; white-space: nowrap; }
  .badge.won { background: var(--won-bg); color: var(--won); }
  .badge.lost { background: var(--lost-bg); color: var(--lost); }

  .criteria-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px 20px; }
  .crit-block .top { display: flex; justify-content: space-between; font-size: 12px; color: var(--text-secondary); margin-bottom: 4px; }
  .diff { font-weight: 600; }
  .diff.bad { color: var(--lost); }
  .diff.neutral { color: var(--text-secondary); font-weight: 400; }
  .bar-row { display: flex; align-items: center; gap: 8px; margin-bottom: 3px; }
  .bar-track { flex: 1; background: var(--surface-muted); border-radius: 3px; height: 6px; overflow: hidden; }
  .bar-fill { height: 100%; border-radius: 3px; }
  .bar-fill.ours { background: var(--ours); }
  .bar-fill.win { background: var(--won); }
  .bar-label { font-size: 11px; color: var(--text-muted); min-width: 70px; text-align: right; }
  .text-compare { display: flex; gap: 8px; flex-wrap: wrap; }
  .text-pill { font-size: 12px; padding: 4px 10px; border-radius: 6px; background: var(--surface-muted); }
  .text-pill .who { color: var(--text-muted); margin-right: 4px; }

  .empty { text-align: center; padding: 2.5rem 1rem; color: var(--text-secondary); }
  .status-msg { font-size: 12px; margin-top: 8px; min-height: 16px; }
  .status-msg.ok { color: var(--won); }
  .status-msg.err { color: var(--lost); }
  .hint { font-size: 12px; color: var(--text-muted); margin: 6px 0 10px; }
  code { background: var(--surface-muted); padding: 1px 5px; border-radius: 4px; font-size: 11px; }
</style>
</head>
<body>
<div class="wrap">

  <h1>Hangete dashboard</h1>
  <p class="sub">Meie pakkumuste võrdlus võidetud pakkumustega — vabalt valitavate kriteeriumite lõikes</p>

  <div class="metrics" id="metrics"></div>

  <div class="panel collapsed" id="addPanel">
    <h2 onclick="togglePanel('addPanel')">Lisa uus hange <span class="chev">▾</span></h2>
    <div class="body">
      <div class="grid2">
        <div class="field full">
          <label>Hanke nimi</label>
          <input type="text" id="f_name" placeholder="nt Tarkvaraarenduse raamleping">
        </div>
        <div class="field full">
          <label>Tulemus</label>
          <select id="f_status">
            <option value="lost">Kaotatud</option>
            <option value="won">Võidetud</option>
          </select>
        </div>
      </div>

      <label style="margin-top: 4px;">Kriteeriumid</label>
      <p class="hint">Lisa nii palju kriteeriume kui vaja — hind, tähtaeg, kogemus, proovitöö, ajaplaan jne. Vali tüüp selle järgi, kumb suund on parem, või "tekstiline", kui väärtus pole arv.</p>
      <div id="critRows"></div>
      <button class="small" onclick="addCritRow()">+ Lisa kriteerium</button>

      <div class="row-actions">
        <button class="primary" onclick="addSingle()">Lisa hange</button>
      </div>
      <p class="status-msg" id="singleMsg"></p>

      <div style="border-top: 1px solid var(--border); margin: 18px 0 14px;"></div>

      <label>Või kleebi mitu hanget korraga</label>
      <p class="hint">Üks hange rea kohta, väljad eraldatud sümboliga <code>|</code>. Formaat:<br>
      <code>Nimi | võidetud/kaotatud | Kriteerium:tüüp:meie:võitja | Kriteerium:tüüp:meie:võitja | ...</code><br>
      Tüübid: <code>madalam</code> (väiksem parem, nt hind), <code>kõrgem</code> (suurem parem, nt kogemus), <code>tekst</code> (mittearvuline, nt proovitöö tulemus)</p>
      <textarea id="f_bulk" placeholder="Kontorimööbli tarne | kaotatud | Hind:madalam:48200:44100 | Tähtaeg:madalam:30:21
Tarkvaraarenduse raamleping | kaotatud | Hind:madalam:158000:141000 | Kogemus:kõrgem:3:6 | Proovitöö:tekst:Läbitud:Läbitud
Turvateenuse osutamine | võidetud | Hind:madalam:76500:76500 | Ajaplaan:tekst:Vastas nõuetele:Vastas nõuetele"></textarea>
      <div class="row-actions">
        <button class="primary" onclick="addBulk()">Impordi read</button>
      </div>
      <p class="status-msg" id="bulkMsg"></p>
    </div>
  </div>

  <div class="toolbar">
    <span><span class="legend-dot" style="background:var(--ours)"></span> Meie pakkumus</span>
    <span><span class="legend-dot" style="background:var(--won)"></span> Võidetud pakkumus</span>
    <div class="spacer"></div>
    <label><input type="checkbox" id="onlyLost" onchange="render()"> Näita ainult kaotatud</label>
  </div>

  <div id="tenderList"></div>

</div>

<script>
let tenders = [];
let critRowCount = 0;
const STORAGE_KEY = 'tenders-data-v2';

function togglePanel(id) {
  document.getElementById(id).classList.toggle('collapsed');
}

function fmtVal(v, type) {
  if (type === 'text') return v;
  const n = parseNum(v);
  return new Intl.NumberFormat('et-EE', { maximumFractionDigits: 2 }).format(n);
}

function parseNum(v) {
  if (typeof v === 'number') return v;
  const cleaned = String(v).replace(/[€\s]/g, '').replace(',', '.');
  const n = parseFloat(cleaned);
  return isNaN(n) ? 0 : n;
}

function addCritRow(label, type, ourVal, winVal) {
  critRowCount++;
  const id = 'crit_' + critRowCount;
  const div = document.createElement('div');
  div.className = 'crit-row';
  div.id = id;
  div.innerHTML = `
    <div><label>Kriteerium</label><input type="text" class="c-label" placeholder="nt Kogemus" value="${label ? escapeAttr(label) : ''}"></div>
    <div><label>Tüüp</label>
      <select class="c-type">
        <option value="lower_better" ${type==='lower_better'?'selected':''}>Madalam parem</option>
        <option value="higher_better" ${type==='higher_better'?'selected':''}>Kõrgem parem</option>
        <option value="text" ${type==='text'?'selected':''}>Tekstiline</option>
      </select>
    </div>
    <div><label>Meie väärtus</label><input type="text" class="c-our" placeholder="nt 3" value="${ourVal !== undefined ? escapeAttr(ourVal) : ''}"></div>
    <div><label>Võitja väärtus</label><input type="text" class="c-win" placeholder="nt 6" value="${winVal !== undefined ? escapeAttr(winVal) : ''}"></div>
    <button class="ghost rm" onclick="document.getElementById('${id}').remove()" title="Eemalda">✕</button>
  `;
  document.getElementById('critRows').appendChild(div);
}

function escapeAttr(v) {
  return String(v).replace(/"/g, '&quot;');
}

function readCritRowsFromForm() {
  const rows = document.querySelectorAll('#critRows .crit-row');
  const criteria = [];
  rows.forEach(row => {
    const label = row.querySelector('.c-label').value.trim();
    const type = row.querySelector('.c-type').value;
    const ourValRaw = row.querySelector('.c-our').value.trim();
    const winValRaw = row.querySelector('.c-win').value.trim();
    if (!label || !ourValRaw || !winValRaw) return;
    criteria.push({
      label,
      type,
      ourValue: type === 'text' ? ourValRaw : parseNum(ourValRaw),
      winValue: type === 'text' ? winValRaw : parseNum(winValRaw)
    });
  });
  return criteria;
}

async function loadData() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    tenders = raw ? JSON.parse(raw) : [];
  } catch (e) {
    console.error('Andmete lugemine ebaõnnestus', e);
    tenders = [];
  }
  addCritRow('Hind', 'lower_better');
  addCritRow('Tähtaeg (päeva)', 'lower_better');
  render();
}

async function saveData() {
  try {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(tenders));
  } catch (e) {
    console.error('Salvestamine ebaõnnestus', e);
    alert('Andmete salvestamine ebaõnnestus. Brauseri salvestusruum võib olla täis või blokeeritud.');
  }
}

function computeMetrics() {
  const total = tenders.length;
  const won = tenders.filter(t => t.status === 'won').length;
  const lost = tenders.filter(t => t.status === 'lost');

  const problemCount = {};
  lost.forEach(t => {
    (t.criteria || []).forEach(c => {
      let worse = false;
      if (c.type === 'lower_better') worse = parseNum(c.ourValue) > parseNum(c.winValue);
      else if (c.type === 'higher_better') worse = parseNum(c.ourValue) < parseNum(c.winValue);
      if (worse) problemCount[c.label] = (problemCount[c.label] || 0) + 1;
    });
  });
  let topProblem = null, topCount = 0;
  Object.entries(problemCount).forEach(([label, count]) => {
    if (count > topCount) { topProblem = label; topCount = count; }
  });

  return { total, won, topProblem, topCount };
}

function renderMetrics() {
  const m = computeMetrics();
  const el = document.getElementById('metrics');
  if (m.total === 0) { el.innerHTML = ''; return; }
  el.innerHTML = `
    <div class="metric"><p class="label">Hankeid kokku</p><p class="value">${m.total}</p></div>
    <div class="metric"><p class="label">Võidetud</p><p class="value" style="color:var(--won)">${m.won} / ${m.total}</p></div>
    <div class="metric"><p class="label">Enim probleeme tekitav kriteerium</p><p class="value" style="color:var(--lost); font-size:16px;">${m.topProblem ? m.topProblem + ' (' + m.topCount + 'x)' : '—'}</p></div>
  `;
}

function renderCriterion(c) {
  const diffBad = c.type === 'lower_better'
    ? parseNum(c.ourValue) > parseNum(c.winValue)
    : c.type === 'higher_better'
      ? parseNum(c.ourValue) < parseNum(c.winValue)
      : String(c.ourValue).trim().toLowerCase() !== String(c.winValue).trim().toLowerCase();

  const isEqual = c.type === 'text'
    ? String(c.ourValue).trim().toLowerCase() === String(c.winValue).trim().toLowerCase()
    : parseNum(c.ourValue) === parseNum(c.winValue);

  let diffLabel = '';
  if (c.type !== 'text') {
    const pct = c.winValue ? Math.round(((parseNum(c.ourValue) - parseNum(c.winValue)) / parseNum(c.winValue)) * 1000) / 10 : 0;
    diffLabel = isEqual ? 'Võrdne' : (pct > 0 ? '+' : '') + pct + '%';
  } else {
    diffLabel = isEqual ? 'Sama' : 'Erinev';
  }

  if (c.type === 'text') {
    return `
      <div class="crit-block">
        <div class="top"><span>${escapeHtml(c.label)}</span><span class="diff ${diffBad ? 'bad' : 'neutral'}">${diffLabel}</span></div>
        <div class="text-compare">
          <span class="text-pill"><span class="who">Meie</span>${escapeHtml(String(c.ourValue))}</span>
          <span class="text-pill"><span class="who">Võitja</span>${escapeHtml(String(c.winValue))}</span>
        </div>
      </div>
    `;
  }

  const maxV = Math.max(parseNum(c.ourValue), parseNum(c.winValue), 1);
  const ourBar = Math.max(2, Math.round((parseNum(c.ourValue) / maxV) * 100));
  const winBar = Math.max(2, Math.round((parseNum(c.winValue) / maxV) * 100));

  return `
    <div class="crit-block">
      <div class="top"><span>${escapeHtml(c.label)}</span><span class="diff ${diffBad ? 'bad' : 'neutral'}">${diffLabel}</span></div>
      <div class="bar-row"><div class="bar-track"><div class="bar-fill ours" style="width:${ourBar}%"></div></div><span class="bar-label">${fmtVal(c.ourValue, c.type)}</span></div>
      <div class="bar-row"><div class="bar-track"><div class="bar-fill win" style="width:${winBar}%"></div></div><span class="bar-label">${fmtVal(c.winValue, c.type)}</span></div>
    </div>
  `;
}

function renderList() {
  const onlyLost = document.getElementById('onlyLost').checked;
  const container = document.getElementById('tenderList');
  const data = onlyLost ? tenders.filter(t => t.status === 'lost') : tenders;

  if (tenders.length === 0) {
    container.innerHTML = '<div class="empty">Hankeid pole veel lisatud. Kasuta ülal olevat vormi, et esimene hange sisestada.</div>';
    return;
  }
  if (data.length === 0) {
    container.innerHTML = '<div class="empty">Kaotatud hankeid pole.</div>';
    return;
  }

  container.innerHTML = data.map(t => {
    const won = t.status === 'won';
    return `
      <div class="tender">
        <div class="tender-head">
          <span class="name">${escapeHtml(t.name)}</span>
          <div style="display:flex; align-items:center; gap:8px;">
            <span class="badge ${won ? 'won' : 'lost'}">${won ? 'Võidetud' : 'Kaotatud'}</span>
            <button class="ghost" onclick="deleteTender('${t.id}')" title="Kustuta">✕</button>
          </div>
        </div>
        <div class="criteria-grid">
          ${(t.criteria || []).map(renderCriterion).join('')}
        </div>
      </div>
    `;
  }).join('');
}

function escapeHtml(str) {
  const d = document.createElement('div');
  d.textContent = str;
  return d.innerHTML;
}

function render() {
  renderMetrics();
  renderList();
}

async function addSingle() {
  const name = document.getElementById('f_name').value.trim();
  const status = document.getElementById('f_status').value;
  const criteria = readCritRowsFromForm();
  const msg = document.getElementById('singleMsg');

  if (!name || criteria.length === 0) {
    msg.textContent = 'Sisesta nimi ja vähemalt üks täidetud kriteerium.';
    msg.className = 'status-msg err';
    return;
  }

  tenders.push({ id: crypto.randomUUID(), name, status, criteria });
  await saveData();
  render();

  document.getElementById('f_name').value = '';
  document.getElementById('critRows').innerHTML = '';
  addCritRow('Hind', 'lower_better');
  addCritRow('Tähtaeg (päeva)', 'lower_better');
  msg.textContent = 'Hange lisatud.';
  msg.className = 'status-msg ok';
  setTimeout(() => { msg.textContent = ''; }, 2500);
}

async function addBulk() {
  const raw = document.getElementById('f_bulk').value.trim();
  const msg = document.getElementById('bulkMsg');
  if (!raw) {
    msg.textContent = 'Kleebi vähemalt üks rida.';
    msg.className = 'status-msg err';
    return;
  }

  const typeMap = { 'madalam': 'lower_better', 'kõrgem': 'higher_better', 'korgem': 'higher_better', 'tekst': 'text' };
  const lines = raw.split('\n').map(l => l.trim()).filter(Boolean);
  let added = 0, skipped = 0;

  lines.forEach(line => {
    const parts = line.split('|').map(p => p.trim());
    if (parts.length < 3) { skipped++; return; }
    const name = parts[0];
    const statusRaw = parts[1];
    if (!name) { skipped++; return; }
    const status = /v[õo]it/i.test(statusRaw) ? 'won' : 'lost';

    const criteria = [];
    for (let i = 2; i < parts.length; i++) {
      const segs = parts[i].split(':').map(s => s.trim());
      if (segs.length < 4) continue;
      const [label, typeRaw, ourRaw, winRaw] = segs;
      const type = typeMap[typeRaw.toLowerCase()] || 'text';
      criteria.push({
        label,
        type,
        ourValue: type === 'text' ? ourRaw : parseNum(ourRaw),
        winValue: type === 'text' ? winRaw : parseNum(winRaw)
      });
    }
    if (criteria.length === 0) { skipped++; return; }
    tenders.push({ id: crypto.randomUUID(), name, status, criteria });
    added++;
  });

  await saveData();
  render();
  document.getElementById('f_bulk').value = '';
  msg.textContent = `${added} hanget lisatud${skipped ? ', ' + skipped + ' rida vahele jäetud (vale formaat)' : ''}.`;
  msg.className = skipped && !added ? 'status-msg err' : 'status-msg ok';
}

async function deleteTender(id) {
  tenders = tenders.filter(t => t.id !== id);
  await saveData();
  render();
}

loadData();
</script>
</body>
</html>
